# Required — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_key

# Required — get yours at https://app.tavily.com
TAVILY_API_KEY=your_tavily_key

# Optional — max tokens of chat history sent to the model per turn (default: 8000).
# Groq free-tier accounts have tight TPM limits; increase this value if you have
# a paid plan and want to support longer multi-turn conversations.
# MAX_HISTORY_TOKENS=8000
